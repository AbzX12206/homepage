{
  "manifest_version": 3,
  "name": "My Custom New Tab",
  "version": "1.2",
  "description": "Replaces default homepage to custom",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "host_permissions": [
    "https://api.open-meteo.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
